# Krackn Hive configuration
# Copy to .env and adjust. All vars use KRACKN_ prefix.

# Database (required for API)
KRACKN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/krackn_hive

# Redis (optional; set KRACKN_EVENT_BUS=redis to use)
KRACKN_REDIS_URL=redis://localhost:6379/0
KRACKN_EVENT_BUS=memory

# Swarm tuning
KRACKN_ABANDONMENT_TTL_SECONDS=900
KRACKN_GLOBAL_BUDGET_TOKENS=100
